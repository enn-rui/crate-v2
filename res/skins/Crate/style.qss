/*******************************************************************************
 ** Buttons  *******************************************************************
 *******************************************************************************/

WPushButton,
WEffectChainPresetButton,
#BpmLockToggle[value="1"],
#LoopAnchor[value="1"] {
    color: #f4f7fb;
    background-color: #1a1f29;
    border: 1px solid #1a1f29;
    border-radius: 2px;
    outline: none;
}

WPushButton:hover,
#PlayToggle:hover,
WEffectChainPresetButton:hover,
#BpmLockToggle[value="1"]:hover,
#LoopAnchor[value="1"]:hover {
    color: #f4f7fb;
    background-color: #232a36;
    border: 1px solid #232a36;
}

/*"Pressed" state*/
WPushButton[value="1"],
WPushButton[value="2"],
#PlayToggle[value="1"] {
    color: #f4f7fb;
    background-color: #2c4a73;
    border: 1px solid #2c4a73;
}
WPushButton#SyncLeader[value="1"] {
    background-color: #1a1f29;
    border: 1px solid #0092d9;
}
WPushButton#SyncLeader[value="0"] {
  image: url(skin:/icon/ic_sync_leader_off.svg) no-repeat center center;
}
WPushButton#SyncLeader[value="1"],
WPushButton#SyncLeader[value="2"] {
  image: url(skin:/icon/ic_sync_leader_on.svg) no-repeat center center;
}

WPushButton[value="1"]:hover,
WPushButton[value="2"]:hover,
#PlayToggle[value="1"]:hover {
    color: #f4f7fb;
    background-color: #b4d2ff;
    border: 1px solid #b4d2ff;
}

#HotcueButton {
  border: none;
}

#HotcueButton[light="true"] {
    color: #1f1e1e;
}
#HotcueButton[light="true"][type="loop"] {
  image: url(skin:/icon/ic_hotcue_loop_dark_48px.svg) no-repeat center center;
}
#HotcueButton[dark="true"][type="loop"] {
  image: url(skin:/icon/ic_hotcue_loop_light_48px.svg) no-repeat center center;
}

#PlayToggle {
  background-color: none;
  border: 1px solid transparent;
}

WPushButton#PlayToggle[value="0"] {
  image: url(skin:/icon/ic_play_48px.svg) no-repeat center center;
  background-color: transparent;
}

WPushButton#PlayToggle[value="1"] {
  image: url(skin:/icon/ic_pause_48px.svg) no-repeat center center;
}
WPushButton#PreviewIndicator {
  background-color: transparent;
}
/* Blue border for Play buttons when previewing from
  Cue or Hotcue */
WPushButton#PreviewIndicator[value="1"] {
  border: 2px solid #b4d2ff;
}
WPushButton#PreviewIndicator[value="0"] {
  border: none;
}

#ToolbarButton[value="1"] {
    color: #f4f7fb;
    background-color: #5a5a5a;
    border: 3px solid #2c4a73;
    border-radius: 3px;
}

#SkinSectionToggleButton[value="1"]:hover {
    color: #f4f7fb;
    background-color: #232a36;
    border: 3px solid #b4d2ff;
    border-radius: 3px;
}

/* The effect unit mix mode button toggles between
two different modes that are not "on" or "off", so
do not highlight either state. */
#EffectUnitMixModeButton {
  margin: 1px 4px;
  border-radius: 2px;
  border: 0px;
}

#EffectUnitMixModeButton[value="0"]:hover,
#EffectUnitMixModeButton[value="1"]:hover {
    background-color: #232a36;
}

#EffectUnitMixModeButton[value="1"] {
    background-color: #1a1f29;
}


/* Special case "orientation" controls
  0 -- left
  1 -- center / off
  2 -- right
*/
/* Default xfader positions:
  left decks = left xfader
  right decks = right xfader
  auxiliary = center */
#OrientationButtonDeck1[value="0"],
#OrientationButtonDeck3[value="0"],
#OrientationButtonDeck2[value="2"],
#OrientationButtonDeck4[value="2"],
#OrientationButtonAux[value="1"],
#OrientationButtonSampler[value="1"] {
    color: #f4f7fb;
    background-color: #1a1f29;
    border: 1px solid #1a1f29;
    border-radius: 2px;
    outline: none;
}

#OrientationButtonDeck1[value="0"]:hover,
#OrientationButtonDeck3[value="0"]:hover,
#OrientationButtonDeck2[value="2"]:hover,
#OrientationButtonDeck4[value="2"]:hover,
#OrientationButtonAux[value="1"]:hover,
#OrientationButtonSampler[value="1"]:hover {
    color: #f4f7fb;
    background-color: #232a36;
    border: 0px solid #232a36;
}

/* Highlight xfader special positions != default */
#OrientationButtonDeck1[value="1"],
#OrientationButtonDeck1[value="2"],
#OrientationButtonDeck3[value="1"],
#OrientationButtonDeck3[value="2"],
#OrientationButtonDeck2[value="0"],
#OrientationButtonDeck2[value="1"],
#OrientationButtonDeck4[value="0"],
#OrientationButtonDeck4[value="1"],
#OrientationButtonAux[value="0"],
#OrientationButtonAux[value="2"],
#OrientationButtonSampler[value="0"],
#OrientationButtonSampler[value="2"] {
    color: #f4f7fb;
    background-color: #2c4a73;
    border: 0px solid #2c4a73;
    border-radius: 2px;
    outline: none;
}

#OrientationButtonDeck1[value="1"]:hover,
#OrientationButtonDeck1[value="2"]:hover,
#OrientationButtonDeck3[value="1"]:hover,
#OrientationButtonDeck3[value="2"]:hover,
#OrientationButtonDeck2[value="0"]:hover,
#OrientationButtonDeck2[value="1"]:hover,
#OrientationButtonDeck4[value="0"]:hover,
#OrientationButtonDeck4[value="1"]:hover,
#OrientationButtonAux[value="0"]:hover,
#OrientationButtonAux[value="2"]:hover,
#OrientationButtonSampler[value="0"]:hover,
#OrientationButtonSampler[value="2"]:hover {
    color: #f4f7fb;
    background-color: #b4d2ff;
    border: 0px solid #b4d2ff;
}

/* Special case SamplerPlayButtonRepeating controls
  When sampler is playing, displays same play icon as normal, but
  background is purple instead of blue.
*/

#SamplerPlayButtonRepeating[value="1"] {
    color: #b4d2ff;
    background-color: #b4d2ff;
    border: 0px solid #b4d2ff;
}

#SamplerPlayButtonRepeating[value="1"]:hover {
    color: #8b32ff;
    background-color: #8b32ff;
    border: 0px solid #8b32ff;
}

/* Special case link_type button for effect parameters
  0 -- not linked / default (off)
  1 -- linked (on)
  2 -- split linked left (on)
  3 -- split linked right (on)
  4 -- split linked left/right (on)

  We define only those values (2-4) that are not covered by the existing
  standard button definitions.
  Note: EQ Gain effects cannot be used in split mode (= can be 0 or 1 only)
*/
#EffectSlotParameterLinkButtonsContainer {
    margin: 1px 4px;
    qproperty-layoutSpacing: 1;
    border-radius: 2px;
    background-color: #282828;
}

#EffectSlotParameterLinkTypeButton[value="2"] {
    color: none;
    background-color: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 0,
                                      stop: 0 #2c4a73,
                                      stop: 0.33 #2c4a73,
                                      stop: 0.34 #1a1f29,
                                      stop: 0.66 #1a1f29,
                                      stop: 0.67 #1a1f29,
                                      stop: 1 #1a1f29);

    border: 0px solid #2c4a73;
}

#EffectSlotParameterLinkTypeButton[value="2"]:hover {
    color: none;
    background-color: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 0,
                                      stop: 0 #b4d2ff,
                                      stop: 0.33 #b4d2ff,
                                      stop: 0.34 #232a36,
                                      stop: 0.66 #232a36,
                                      stop: 0.67 #232a36,
                                      stop: 1 #232a36);
    border: 0px solid #b4d2ff;
}

#EffectSlotParameterLinkTypeButton[value="3"] {
    color: none;
    background-color: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 0,
                                      stop: 0 #1a1f29,
                                      stop: 0.33 #1a1f29,
                                      stop: 0.34 #1a1f29,
                                      stop: 0.66 #1a1f29,
                                      stop: 0.67 #2c4a73,
                                      stop: 1 #2c4a73);
    border: 0px solid #2c4a73;
}


#EffectSlotParameterLinkTypeButton[value="3"]:hover {
    color: none;
    background-color: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 0,
                                      stop: 0 #232a36,
                                      stop: 0.33 #232a36,
                                      stop: 0.34 #232a36,
                                      stop: 0.66 #232a36,
                                      stop: 0.67 #b4d2ff,
                                      stop: 1 #b4d2ff);
    border: 0px solid #b4d2ff;
}

#EffectSlotParameterLinkTypeButton[value="4"] {
    color: none;
    background-color: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 0,
                                      stop: 0 #2c4a73,
                                      stop: 0.330000 #2c4a73,
                                      stop: 0.340000 #1a1f29,
                                      stop: 0.660000 #1a1f29,
                                      stop: 0.670000 #2c4a73,
                                      stop: 1 #2c4a73);
    border: 0px solid #2c4a73;
}


#EffectSlotParameterLinkTypeButton[value="4"]:hover {
    color: none;
    background-color: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 0,
                                      stop: 0 #b4d2ff,
                                      stop: 0.330000 #b4d2ff,
                                      stop: 0.340000 #232a36,
                                      stop: 0.660000 #232a36,
                                      stop: 0.670000 #b4d2ff,
                                      stop: 1 #b4d2ff);
    border: 0px solid #b4d2ff;
}

#EffectSlotParameterLinkInversionButton[value="1"] {
    background-color: #b90505;
    border: 1px solid #b90505;
}

#EffectSlotParameterLinkInversionButton[value="1"]:hover {
    background-color: #e80808;
    border: 1px solid #FF0808;
}

/* Special case "hide/show" button
   The button unfolds/folds widgets. We display different icons per state, but
   do not want an active or active:hover color like with the other buttons.
*/
#ShowHideToggle {
  qproperty-layoutAlignment: 'AlignTop';
  padding-top: 3px;
}

#SampleDeckToggle[value="1"], #LibraryToggle[value="1"], #EffectRackToggle[value="1"] {
    color: #f4f7fb;
    background-color: #1a1f29;
    border: 1px solid #1a1f29;
    border-radius: 2px;
    outline: none;
}

#SampleDeckToggle[value="1"]:hover, #LibraryToggle[value="1"]:hover, #EffectRackToggle[value="1"]:hover {
    color: #f4f7fb;
    background-color: #232a36;
    border: 0px solid #232a36;
}

#WaveformZoomDownButton[value="0"]:!hover,
#WaveformZoomSetDefaultButton[value="0"]:!hover,
#WaveformZoomUpButton[value="0"]:!hover {
  background: none;
  border: none;
}

#BeatJumpValue, #LoopMoveValue, #HotcueButton, #DeckCue, #DeckSync, #BeatsyncButton {
  font: bold 12px;
}

/*******************************************************************************
 ** End Buttons  ***************************************************************
 *******************************************************************************/


/* common styles for WEffectSelector, QMenu, QToolTip */
WEffectSelector QAbstractScrollArea {
  min-width: 160px;
}
WEffectChainPresetSelector QAbstractScrollArea {
  min-width: 140px;
}
#fadeModeCombobox QAbstractScrollArea {
  min-width: 185px;
}
QToolTip,
#MainMenu,
#MainMenu::item,
#MainMenu QMenu,
#MainMenu QMenu::item,
#MainMenu QMenu QCheckBox,
#ToolBar,
WLibrarySidebar QMenu,
WLibrarySidebar QMenu::item,
WTrackTableViewHeader QMenu,
WTrackTableViewHeader QMenu::item,
WTrackTableViewHeader QMenu QCheckBox,
WLibraryTextBrowser QMenu,
WLibraryTextBrowser QMenu::item,
WTrackMenu,
WTrackMenu::item,
WTrackMenu QMenu,
WTrackMenu QMenu::item,
WTrackMenu QMenu QCheckBox,
WTrackMenu WStarRating,
QLineEdit QMenu,
QLineEdit QMenu::item,
QPlainTextEdit QMenu,
QPlainTextEdit QMenu::item,
WCoverArtMenu,
WCoverArtMenu::item,
WCueMenuPopup,
WCueMenuPopup QLabel,
WEffectSelector::item:!selected,
WEffectSelector QAbstractScrollArea,
WEffectChainPresetSelector::item:!selected,
WEffectChainPresetSelector QAbstractScrollArea,
WSearchLineEdit::item:!selected,
WSearchLineEdit QAbstractScrollArea,
#fadeModeCombobox::item:!selected,
#fadeModeCombobox QAbstractScrollArea {
  color: #c1cabe;
  background-color: #201f1f;
}
QToolTip,
WLibrarySidebar QMenu,
WTrackTableViewHeader QMenu,
WLibraryTextBrowser QMenu,
WTrackMenu,
WTrackMenu QMenu,
QLineEdit QMenu,
QPlainTextEdit QMenu,
WCueMenuPopup,
WCoverArtMenu,
WEffectSelector QAbstractScrollArea,
WEffectChainPresetSelector QAbstractScrollArea,
WSearchLineEdit QAbstractScrollArea,
#fadeModeCombobox QAbstractScrollArea {
  border-width: 1px;
  border-style: solid;
  border-color: #aaa;
  border-radius: 1px;
}
  /* hovered items */
  #MainMenu::item:selected,
  #MainMenu QMenu::item:selected,
  #MainMenu QMenu::item:focus,
  #MainMenu QMenu::item:hover,
  #MainMenu QMenu::indicator:checked:selected,
  #MainMenu QMenu::indicator:unchecked:selected,
  WLibrarySidebar QMenu::item:selected,
  WLibrarySidebar QMenu::indicator:unchecked:selected,
  WTrackTableViewHeader QMenu::item:selected,
  WTrackTableViewHeader QMenu QCheckBox:selected,
  WTrackTableViewHeader QMenu QCheckBox:focus,
  WTrackTableViewHeader QMenu QCheckBox:hover,
  WLibraryTextBrowser QMenu::item:selected,
  WTrackMenu::item:selected,
  WTrackMenu QMenu::item:selected,
  WTrackMenu QMenu QCheckBox:selected,
  WTrackMenu QMenu QCheckBox:focus,
  WTrackMenu QMenu QCheckBox:hover,
  QLineEdit QMenu::item:selected,
  QPlainTextEdit QMenu::item:selected,
  WCoverArtMenu::item:selected,
  WEffectSelector::item:selected,
  WEffectSelector::indicator:unchecked:selected,
  WEffectChainPresetSelector::item:selected,
  WEffectChainPresetSelector::indicator:unchecked:selected,
  WSearchLineEdit::item:selected,
  WSearchLineEdit::indicator:unchecked:selected,
  #fadeModeCombobox::item:selected,
  #fadeModeCombobox::indicator:unchecked:selected {
    background-color: #565353;
    color: #fff;
    /* remove OS focus indicator */
    outline: none;
    }
    /* required on Windows since the QAbstractItemViews don't inherit styles from
       the respective QComboBoxes */
    WEffectSelector QAbstractItemView,
    WEffectChainPresetSelector QAbstractItemView,
    WSearchLineEdit QAbstractItemView {
      selection-color: #fff;
      selection-background-color: #565353;
      border: 0px;
      outline: none;
    }
    /* Remove 3D border from unchecked effects checkmark space */
    WEffectSelector::item:selected,
    WEffectChainPresetSelector::item:selected,
    WSearchLineEdit::item:selected,
    #fadeModeCombobox::item:selected {
      border: 0px;
    }

/* It is difficult to achieve identical styles WMainMenuBar #MainMenu
  on Windows AND Linux because item and checkbox properties are rendered
  slightly different.
  For details see
    * default-menu-styles-linux.qss
    * default-menu-styles-windows.qss
  Common styles are set here.
  Luckily we don't need to care about macOS here -Woohoo!- because
  there the menu bar is always styled natively. */
#MainMenu {
  margin-bottom: 0px;
  padding-bottom: 0px;
}
  #MainMenu QMenu::indicator:checked,
  #MainMenu QMenu::indicator:checked:selected {
    image: url(skin:/icon/ic_mainmenu_checkbox_checked.svg);
  }
  #MainMenu QMenu::indicator:unchecked,
  #MainMenu QMenu::indicator:unchecked:selected {
    image: url(skin:/icon/ic_mainmenu_checkbox.svg);
  }

#MainMenu QMenu {
  padding: 0.08em;
  border: 1px solid #888;
  border-radius: 2px;
  }
  #MainMenu QMenu::right-arrow,
  WTrackMenu::right-arrow,
  WTrackMenu QMenu::right-arrow {
    width: 0.7em;
    height: 0.7em;
    image: url(skin:/icon/ic_chevron_right_48px.svg);
  }


WEffectSelector:!editable,
WEffectChainPresetSelector:!editable,
#fadeModeCombobox:!editable {
  color: #c1cabe;
  /* The 3D frame on the combo box becomes flat when you give it a border */
  border: 1px solid #444342;
  border-radius: 3px;
  }
  WEffectSelector:!editable,
  #fadeModeCombobox:!editable {
    font: 15px;
  }
  WEffectChainPresetSelector:!editable {
    font: 13px;
  }
WEffectSelector:!editable,
WEffectSelector:!editable:on,
WEffectChainPresetSelector:!editable,
WEffectChainPresetSelector:!editable:on {
  /* Fixes the white bars on the top/bottom of the popup on Mac OS X */
  margin: 0px;
  /* If you use margin top/bottom 0, the combo box shrinks in width (go figure) and
   * names start getting cut off. Adding explicit padding improves this. */
  padding: 0px 6px;
  background-color: #404040;
}
#fadeModeCombobox {
  /* 1px is added in each dimension. 20+1+1 = 22 = button height */
  height: 20px;
  padding: 0px 6px;
  margin: 9px 3px 6px 3px;
}

  WEffectSelector:!editable:hover,
  WEffectChainPresetSelector:!editable:hover,
  #fadeModeCombobox:!editable:hover {
    border: 1px ridge #015d8d;
  }
  WEffectSelector::drop-down,
  WEffectChainPresetSelector::drop-down,
  WSearchLineEdit::drop-down,
  WEffectChainPresetSelector::drop-down,
  #fadeModeCombobox::drop-down {
    /* This causes the Qt theme's widget style to magically not apply. Go figure. */
    border: 0;
  }
  WEffectSelector::down-arrow,
  #fadeModeCombobox::down-arrow {
    width: 20px;
    height: 20px;
  }
  WEffectChainPresetSelector::down-arrow {
    width: 16px;
    height: 16px;
  }
  WEffectSelector::down-arrow,
  WSearchLineEdit::down-arrow,
  WEffectChainPresetSelector::down-arrow,
  #fadeModeCombobox::down-arrow {
    image: url(skin:/icon/ic_chevron_down_48px.svg);
  }
  /* currently loaded effect */
  WEffectSelector::checked,
  WEffectChainPresetSelector::checked,
  #fadeModeCombobox::checked {
    color: #b4d2ff;
    font-weight: bold;
  }
  WEffectSelector::indicator:checked,
  WEffectChainPresetSelector::indicator:checked,
  #fadeModeCombobox::indicator:checked {
    /* checkbox container is 28 x 22px;
      use margin + border to create a square checkbox sized like kill buttons */
    margin: 2px 0px 2px 5px;
  }

  /* QuickEffect selector of left-hand decks and in 4-decks mixer
    has it's down arrow on the left side, below the QuickEffect toggle */
  WEffectChainPresetSelector#QuickEffectSelectorLeft {
    padding: 0px -2px 0px -1px;
    margin: 0px;
    text-align: left;
    }
    WEffectChainPresetSelector#QuickEffectSelectorLeft::drop-down {
      subcontrol-origin: margin;
      subcontrol-position: left center;
    }
  WEffectChainPresetSelector#QuickEffectSelectorRight {
    padding: 0px -1px 0px -2px;
    margin: 0px;
    text-align: right;
    }
    WEffectChainPresetSelector#QuickEffectSelectorRight::drop-down {
      subcontrol-origin: margin;
      subcontrol-position: right center;
    }

WEffectSelector::checked, /* selected item */
WEffectSelector::indicator, /* checkbox, tick mark */
WEffectSelector::drop-down,
WEffectSelector::indicator:unchecked,
WEffectChainPresetSelector::checked,
WEffectChainPresetSelector::indicator,
WEffectChainPresetSelector::drop-down,
WEffectChainPresetSelector::indicator:unchecked,
WSearchLineEdit::checked,
WSearchLineEdit::indicator,
WSearchLineEdit::drop-down,
WSearchLineEdit::indicator:unchecked,
#fadeModeCombobox::checked,
#fadeModeCombobox::indicator,
#fadeModeCombobox::drop-down,
#fadeModeCombobox::indicator:unchecked {
  padding: 0px;
  margin: 0px;
  image: none;
  outline: none;
  border: 0px solid transparent;
}

#MainMenu QMenu::separator,
WLibrarySidebar QMenu::separator,
WTrackTableViewHeader QMenu::separator,
WTrackMenu::separator,
WTrackMenu QMenu::separator,
WLibraryTextBrowser QMenu::separator,
QLineEdit QMenu::separator,
QPlainTextEdit QMenu::separator {
  border-top: 1px solid #999;
}

WLibrarySidebar QMenu::indicator,
WTrackTableViewHeader QMenu QCheckBox::indicator,
WTrackMenu QMenu QCheckBox::indicator {
  border: 1px solid #555;
  border-radius: 1px;
  background-color: #0f0f0f;
  /* remove OS focus indicator */
  outline: none;
}
WSearchRelatedTracksMenu #SearchSelectedAction::indicator {
  border: 0px;
  background-color: transparent;
}

WLibrarySidebar QMenu::indicator:selected,
WTrackTableViewHeader QMenu QCheckBox::indicator:selected,
WTrackMenu QMenu QCheckBox::indicator:selected {
  border: 1px solid #999;
}
/* disabled menu items and checkboxes */
#MainMenu::item:disabled,
#MainMenu QMenu::item:disabled,
WLibrarySidebar QMenu::item:disabled,
WLibraryTextBrowser QMenu::item:disabled,
WTrackMenu::item:disabled,
WTrackMenu QMenu::item:disabled,
WTrackMenu QMenu QCheckBox:disabled,
QLineEdit QMenu::item:disabled,
QPlainTextEdit QMenu::item:disabled {
  color: #555;
}
WTrackMenu QMenu QCheckBox::indicator:disabled {
  border: 1px solid #222;
  background-color: #333;
}
WLibrarySidebar QMenu::indicator:checked,
WTrackTableViewHeader QMenu QCheckBox::indicator:checked,
WTrackMenu QMenu QCheckBox::indicator:checked {
  image: url(skin:/icon/ic_library_checkmark_orange.svg);
}
WTrackTableViewHeader QMenu::indicator:checked,
WEffectSelector::indicator:checked,
WEffectChainPresetSelector::indicator:checked,
#fadeModeCombobox::indicator:checked {
  image: url(skin:/icon/ic_library_checkmark_blue.svg);
}

/* disabled menu item and checkbox */
WTrackMenu QMenu QCheckBox::indicator:disabled:unchecked,
WTrackMenu QMenu QCheckBox::indicator:disabled:checked,
WTrackMenu QMenu QCheckBox::indicator:indeterminate {
  background-color: #222;
}
WTrackMenu QMenu QCheckBox::indicator:disabled:checked {
  image: url(skin:/icon/ic_library_checkmark_grey.svg);
}
WTrackMenu QMenu QCheckBox::indicator:indeterminate {
  image: url(skin:/icon/ic_library_checkmark_indeterminate_orange.svg);
}
WTrackMenu QMenu QCheckBox::indicator:disabled:indeterminate {
  image: url(skin:/icon/ic_library_checkmark_indeterminate_grey.svg);
}
WTrackMenu QMenu QCheckBox::indicator:disabled:checked,
WTrackMenu QMenu QCheckBox::indicator:disabled:unchecked {
  border: 1px solid #222;
}

/* explicitly remove icons from unchecked items otherwise
  selected, unchecked items would have a checkmark */
WLibrarySidebar QMenu::indicator:unchecked,
WLibrarySidebar QMenu::indicator:unchecked:selected,
WTrackTableViewHeader QMenu::indicator:unchecked,
WTrackTableViewHeader QMenu::indicator:unchecked:selected,
WEffectSelector::indicator:unchecked,
WEffectSelector::indicator:unchecked:selected,
WEffectChainPresetSelector::indicator:unchecked,
WEffectChainPresetSelector::indicator:unchecked:selected,
#fadeModeCombobox::indicator:unchecked,
#fadeModeCombobox::indicator:unchecked:selected {
  image: none;
}
/* common styles for WEffectSelector, QMenu, QToolTip */

/* widgets in cue popup menu */
#CueLabelEdit {
  padding: 2px;
  border: 1px solid #1a1f29;
  background-color: #0f0f0f;
  color: #f4f7fb;
  selection-color: #05060a;
  selection-background-color: #f4f7fb;
}

#CueDeleteButton {
/* tall button, about the same height as cue number + label edit box */
  width: 28px;
  height: 46px;
  /* make the icon slightly larger than default 16px */
  qproperty-iconSize: 20px;
  qproperty-icon: url(skin:/icon/ic_delete.svg);
  background-color: #3B3B3B;
  border-radius: 2px;
  outline: none;
}

#CueStandardButton {
/* tall button, about the same height as cue number + label edit box */
  width: 28px;
  height: 46px;
  /* make the icon slightly larger than default 16px */
  qproperty-iconSize: 20px;
  qproperty-icon: url(skin:/icon/ic_loop_in_48px.svg);
  background-color: #3B3B3B;
  border-radius: 2px;
  outline: none;
}

#CueSavedLoopButton {
/* tall button, about the same height as cue number + label edit box */
  width: 28px;
  height: 46px;
  /* make the icon slightly larger than default 16px */
  qproperty-iconSize: 20px;
  qproperty-icon: url(skin:/icon/ic_loop_48px.svg);
  background-color: #3B3B3B;
  border-radius: 2px;
  outline: none;
}

#CueSavedJumpButton {
/* tall button, about the same height as cue number + label edit box */
  width: 28px;
  height: 46px;
  /* make the icon slightly larger than default 16px */
  qproperty-iconSize: 20px;
  qproperty-icon: url(skin:/icon/ic_beatjump_forward_48px.svg);
  background-color: #3B3B3B;
  border-radius: 2px;
  outline: none;
}

#CueDeleteButton:hover, #CueStandardButton:hover, #CueSavedLoopButton:hover, #CueSavedJumpButton:hover {
  background-color: #1a1f29;
}

#CueDeleteButton:checked, #CueStandardButton:checked, #CueSavedLoopButton:checked, #CueSavedJumpButton:checked {
  background-color: #2c4a73;
}

WRateRange {
    font-size: 10px;
}

#RateDisplayTopPrefix {
    qproperty-alignment: 'AlignLeft | AlignTop';
}
#RateDisplayTopRate {
    qproperty-alignment: 'AlignRight | AlignTop';
}

#RateDisplayBottomPrefix {
    qproperty-alignment: 'AlignLeft | AlignBottom';
}
#RateDisplayBottomRate {
    qproperty-alignment: 'AlignRight | AlignBottom';
}

/*******************************************************************************
 ** CRATE TERMINAL IDENTITY ****************************************************
 ** Flat ink-on-black pass. Keep this final so it deliberately supersedes the
 ** inherited Deere geometry without duplicating its mature layout rules.
 *******************************************************************************/

QWidget {
  color: #f4f7fb;
  font-family: "IBM Plex Mono", "Cascadia Mono", "Consolas";
  font-size: 12px;
  selection-color: #f4f7fb;
  selection-background-color: rgba(180, 210, 255, 140);
}

QMainWindow,
#MainWindow,
#MainWidget,
#CentralWidget,
#MainDecks,
#MainDeckContainer,
#Deck1, #Deck2, #Deck3, #Deck4,
#DeckRows,
#DeckSmall,
#DeckControls,
#DeckControlsGrid,
#Mixer,
#DeckMixer,
#MixerBorder,
#MainControls,
#HeadphoneControls,
#LibraryContainer,
#LibrarySplitter,
#SkinSettings,
#SkinSettingsTop {
  background-color: #05060a;
  color: #f4f7fb;
}

#Deck1, #Deck2, #Deck3, #Deck4,
#DeckTextRowSmall,
#ArtistKeyBpmGutter,
#VisualRow,
#OverviewRow,
#ControlsRow,
#DeckRateSliderColumn,
#Sampler,
#SamplerMiddleSpacer,
#SamplerRow1, #SamplerRow2, #SamplerRow3, #SamplerRow4,
#SamplerRow5, #SamplerRow6, #SamplerRow7, #SamplerRow8 {
  border-color: rgba(244, 247, 251, 36);
}

#MixerBorder,
#Spacer22,
#Spacer33 {
  background-color: rgba(244, 247, 251, 26);
}

WLabel,
QLabel,
#Deck1 WLabel, #Deck2 WLabel, #Deck3 WLabel, #Deck4 WLabel {
  color: #f4f7fb;
}

WLibraryTextBrowser,
WTrackTableView,
WLibrarySidebar {
  color: #f4f7fb;
  background-color: #05060a;
  alternate-background-color: rgba(244, 247, 251, 8);
  border: 1px solid rgba(244, 247, 251, 36);
  gridline-color: rgba(244, 247, 251, 20);
  selection-color: #f4f7fb;
  /* Precomposited 24% cold blue on #05060a: Mixxx delegates discard alpha. */
  selection-background-color: #2f3745;
  outline: 0;
}

#DlgMissing WTrackTableView { qproperty-trackMissingColor: #f4f7fb; }

WTrackTableView::item:selected,
WLibrarySidebar::item:selected,
#LibraryBPMButton::item:selected,
#LibraryPlayedCheckbox::item:selected {
  color: #f4f7fb;
  background-color: #2f3745;
}

WTrackTableView::item:!selected:focus,
WLibrarySidebar::item:!selected:focus,
WLibrarySidebar[dragHover="true"]::item:hover {
  background-color: rgba(180, 210, 255, 26);
  border: 1px solid rgba(180, 210, 255, 122);
}

WTrackTableViewHeader,
WTrackTableViewHeader::section {
  color: rgba(244, 247, 251, 179);
  background-color: #05060a;
  border-color: rgba(244, 247, 251, 36);
}

WLibrary QLineEdit,
WLibrary QPlainTextEdit,
QLineEdit,
QComboBox,
QSpinBox,
#LibraryBPMSpinBox,
#CueLabelEdit {
  color: #f4f7fb;
  background-color: rgba(244, 247, 251, 13);
  border: 1px solid rgba(244, 247, 251, 51);
  selection-color: #f4f7fb;
  selection-background-color: rgba(180, 210, 255, 82);
}

WPushButton,
QPushButton,
#LibraryFeatureControls QPushButton,
#SkinSettingsButton,
#SkinSettingsCategoryButton {
  color: rgba(244, 247, 251, 224);
  background-color: rgba(244, 247, 251, 15);
  border: 1px solid rgba(244, 247, 251, 46);
  border-radius: 0;
}

WPushButton:hover,
QPushButton:hover,
#LibraryFeatureControls QPushButton:hover,
#SkinSettingsButton:hover,
#SkinSettingsCategoryButton:hover {
  color: #f4f7fb;
  background-color: rgba(180, 210, 255, 26);
  border-color: rgba(180, 210, 255, 140);
}

WPushButton[value="1"],
WPushButton[value="2"],
QPushButton:checked {
  color: #f4f7fb;
  background-color: rgba(180, 210, 255, 46);
  border-color: rgba(180, 210, 255, 179);
}

WPushButton#SyncLeader[value="1"],
WPushButton#SyncLeader[value="2"] {
  color: #eafff0;
  background-color: rgba(91, 217, 122, 61);
  border-color: #5bd97a;
}

#CueDeleteButton {
  color: #ffecec;
  background-color: rgba(255, 120, 120, 36);
  border: 1px solid rgba(255, 120, 120, 140);
}

#CueStandardButton,
#CueSavedLoopButton,
#CueSavedJumpButton {
  color: #fff0df;
  background-color: rgba(255, 159, 67, 31);
  border: 1px solid rgba(255, 159, 67, 122);
}

#CueDeleteButton:checked,
#CueStandardButton:checked,
#CueSavedLoopButton:checked,
#CueSavedJumpButton:checked {
  background-color: rgba(255, 159, 67, 71);
  border-color: #ff9f43;
}

#LibraryContainer QScrollBar:horizontal,
#LibraryContainer QScrollBar:vertical,
QScrollBar:horizontal,
QScrollBar:vertical { background: #05060a; }

#LibraryContainer QScrollBar::handle:horizontal,
#LibraryContainer QScrollBar::handle:vertical,
QScrollBar::handle:horizontal,
QScrollBar::handle:vertical {
  background: rgba(244, 247, 251, 51);
  border: 0;
}

QToolTip,
#MainMenu,
#MainMenu QMenu,
WLibrarySidebar QMenu,
WTrackTableViewHeader QMenu,
WLibraryTextBrowser QMenu,
QLineEdit QMenu {
  color: #f4f7fb;
  background-color: #05060a;
  border-color: rgba(244, 247, 251, 51);
}

#MainMenu::item:selected,
#MainMenu QMenu::item:selected,
WLibrarySidebar QMenu::item:selected,
WTrackTableViewHeader QMenu::item:selected,
WLibraryTextBrowser QMenu::item:selected,
QLineEdit QMenu::item:selected {
  color: #f4f7fb;
  background-color: rgba(180, 210, 255, 51);
}

/* FX routing remains neutral; color is reserved for transport semantics. */
#FxAssignmentButton[value="1"], #FxAssignmentButton[value="2"] {
  color: #f4f7fb;
  background-color: rgba(244, 247, 251, 20);
  border-color: rgba(244, 247, 251, 90);
}

#PlayToggle[value="1"] {
  color: #5bd97a;
  background-color: rgba(91, 217, 122, 46);
  border-color: #5bd97a;
}

#DeckCue { color: #ffb454; border-color: rgba(255, 180, 84, 140); }
#BpmKeyEditTriggerLabel, #RateDisplayTopRate, #RateDisplayBottomRate { color: #ffb454; }

#DeckSync[value="1"], #DeckSync[value="2"],
#BeatsyncButton[value="1"], #BeatsyncButton[value="2"],
#SyncLeader[value="1"], #SyncLeader[value="2"],
#BeatloopActivate[value="1"], #BeatloopActivate[value="2"],
#LoopIn[value="1"], #LoopOut[value="1"], #LoopAnchor[value="1"] {
  color: #5bd97a;
  background-color: rgba(91, 217, 122, 46);
  border-color: #5bd97a;
}

#SlipButton[value="1"], #SlipButton[value="2"],
#ReverseButton[value="1"], #ReverseButton[value="2"],
#CueDeleteButton:checked {
  color: #ff7878;
  background-color: rgba(255, 120, 120, 46);
  border-color: #ff7878;
}

/* Dynamic cue colors are supplied by Mixxx. Do not paint a gray chip over them. */
#HotcueButton {
  border: 1px solid rgba(244, 247, 251, 46);
  border-radius: 0;
}

#HotcueButton[displayValue="0"] {
  color: rgba(244, 247, 251, 179);
  background-color: #05060a;
  border-color: rgba(244, 247, 251, 36);
}

#HotcueButton[displayValue="1"],
#HotcueButton[displayValue="2"] {
  border-color: rgba(244, 247, 251, 122);
}

/*******************************************************************************
 ** Crate v2 wave-5: dropdown + FX/mic ink pass ********************************
 *******************************************************************************
 * Two recurring bugs across QComboBox flavors, fixed repo-wide here:
 *   (1) IBM Plex Mono (wave-4 font) is wider than the paddings the stock Deere
 *       combos were tuned for, so the drop-down arrow overlapped the text. Fix:
 *       a DEFAULT padding-right >= the drop-down button width for every combo.
 *   (2) Some combo popups (QComboBox QAbstractItemView) rendered native-white or
 *       stock-grey with unreadable text, because the popup view does not inherit
 *       the combo's own colors on Windows. Fix: explicit dark ink popups for
 *       every flavor. Palette reused verbatim from the wave-4 identity pass:
 *       ink #f4f7fb, panel #0d1017, deep #05060a, border rgba(244,247,251,51),
 *       cold-blue accent #b4d2ff. No new greys, no VU/font changes.            */

/* (1)+(2) Generic combos: preferences dialogs, library, and any stock QComboBox
   (WComboBox etc.). WEffectSelector-family and #CrateMapControls override below/
   above with their own more-specific rules. */
QComboBox {
  /* drop-down is 18px + 1px border; keep text clear of it under Plex Mono. */
  padding-right: 22px;
}
QComboBox::drop-down {
  subcontrol-origin: padding;
  subcontrol-position: top right;
  width: 18px;
  border-left: 1px solid rgba(244, 247, 251, 51);
}
QComboBox::down-arrow {
  image: url(skin:/image/style_branch_closed.svg);
  width: 8px;
  height: 8px;
}
/* FX-row selectors live in width-tight collapsed unit rows: the generic 22px
   padding-right + 18px drop-down inflated their size hints until the selectors
   slid under the FX1/FX2 toggle (report: "drop down covers the fx1/fx2 text";
   expanded parameter view had room, collapsed view didn't). Short effect names
   need only a slim arrow gutter — keep these subclass rules tighter. */
WEffectSelector,
WEffectChainPresetSelector {
  /* 16px keeps Plex Mono clear of the 10px arrow gutter (12px still grazed
     it); the full FX-row layout gets its own design pass. */
  padding-right: 16px;
}
WEffectSelector::drop-down,
WEffectChainPresetSelector::drop-down {
  subcontrol-origin: padding;
  subcontrol-position: top right;
  width: 10px;
  border-left: none;
}
QComboBox QAbstractItemView {
  color: #f4f7fb;
  background-color: #05060a;
  border: 1px solid rgba(244, 247, 251, 51);
  selection-color: #05060a;
  selection-background-color: #b4d2ff;
  outline: none;
}

/* (2) De-grey the FX / search / AutoDJ combo popups. These were stock warm-grey
   (#201f1f bg, #c1cabe text, #aaa border, #565353 selection) which is exactly
   the "grey has come back ... in drop downs" report. Move them to Crate ink.
   Selectors mirror the earlier grey rules and appear later, so they win. */
WEffectSelector::item:!selected,
WEffectSelector QAbstractScrollArea,
WEffectChainPresetSelector::item:!selected,
WEffectChainPresetSelector QAbstractScrollArea,
WSearchLineEdit::item:!selected,
WSearchLineEdit QAbstractScrollArea,
#fadeModeCombobox::item:!selected,
#fadeModeCombobox QAbstractScrollArea {
  color: #f4f7fb;
  background-color: #05060a;
}
WEffectSelector QAbstractScrollArea,
WEffectChainPresetSelector QAbstractScrollArea,
WSearchLineEdit QAbstractScrollArea,
#fadeModeCombobox QAbstractScrollArea {
  border-color: rgba(244, 247, 251, 51);
}
WEffectSelector::item:selected,
WEffectSelector::indicator:unchecked:selected,
WEffectChainPresetSelector::item:selected,
WEffectChainPresetSelector::indicator:unchecked:selected,
WSearchLineEdit::item:selected,
WSearchLineEdit::indicator:unchecked:selected,
#fadeModeCombobox::item:selected,
#fadeModeCombobox::indicator:unchecked:selected {
  color: #f4f7fb;
  background-color: rgba(180, 210, 255, 82);
}
/* Windows: the popup view does not inherit the combo's styles, so set it too. */
WEffectSelector QAbstractItemView,
WEffectChainPresetSelector QAbstractItemView,
WSearchLineEdit QAbstractItemView,
#fadeModeCombobox QAbstractItemView {
  color: #f4f7fb;
  background-color: #05060a;
  selection-color: #f4f7fb;
  selection-background-color: rgba(180, 210, 255, 82);
  border: 1px solid rgba(244, 247, 251, 51);
  outline: none;
}
/* Closed (collapsed) FX combos: de-grey the box body, border and hover accent. */
WEffectSelector:!editable,
WEffectChainPresetSelector:!editable,
#fadeModeCombobox:!editable {
  color: #f4f7fb;
  border-color: rgba(244, 247, 251, 51);
}
WEffectSelector:!editable,
WEffectSelector:!editable:on,
WEffectChainPresetSelector:!editable,
WEffectChainPresetSelector:!editable:on {
  background-color: rgba(244, 247, 251, 13);
}
WEffectSelector:!editable:hover,
WEffectChainPresetSelector:!editable:hover,
#fadeModeCombobox:!editable:hover {
  border: 1px solid #b4d2ff;
}
WEffectSelector::checked,
WEffectChainPresetSelector::checked,
#fadeModeCombobox::checked {
  color: #b4d2ff;
}
