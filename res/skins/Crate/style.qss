}

#OrientationButtonAux {
}

#LibraryContainer {
  qproperty-layoutAlignment: 'AlignLeft | AlignVCenter';
  background-color: #05060a;
  padding-top: 2px;
}

#LibrarySplitter {
  background-color: #05060a;
}

#EffectRackContainer {
